<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>نظام BRHM لحماية النصوص</title>
  <style>
    body { font-family: sans-serif; background:#111; color:#eee; padding:20px; }
    h1, h2 { color:#0ff; }
    textarea { width:100%; height:150px; margin:5px 0; background:#000; color:#0f0; padding:10px; }
    input, button { padding:8px; margin:5px 0; }
    .section { border:1px solid #333; padding:15px; margin-bottom:20px; border-radius:8px; }
    .label { font-weight:bold; color:#0f9; }
    pre { background:#000; color:#0f0; padding:10px; overflow:auto; }
  </style>
</head>
<body>

  <h1>نظام BRHM التجريبي لحماية النصوص</h1>

  <div class="section">
    <h2>1) تشفير نص وتحويله إلى ملف BRHM</h2>
    <div class="label">النص الأصلي (مثال: فصل من كتاب):</div>
    <textarea id="inputText" placeholder="اكتب هنا النص الذي تريد حمايته..."></textarea>

    <div class="label">مفتاح الشراء (Purchase Key):</div>
    <input id="purchaseKey" type="text" placeholder="مثال: USER-123-ABC" style="width:100%;" />

    <button onclick="encodeToBRHM()">تشفير وتوليد ملف BRHM</button>

    <div class="label">محتوى ملف BRHM (للعرض فقط):</div>
    <pre id="brhmOutput"></pre>

    <button onclick="downloadBRHM()">تحميل ملف BRHM</button>
  </div>

  <div class="section">
    <h2>2) فك ملف BRHM واسترجاع النص</h2>
    <div class="label">رفع ملف BRHM:</div>
    <input type="file" id="brhmFileInput" accept=".brhm,.json" />

    <div class="label">مفتاح الشراء نفسه المستخدم في التشفير:</div>
    <input id="purchaseKeyDecode" type="text" placeholder="نفس المفتاح المستخدم عند التشفير" style="width:100%;" />

    <button onclick="decodeBRHM()">فك ملف BRHM</button>

    <div class="label">النص المسترجع:</div>
    <textarea id="decodedText" readonly></textarea>
  </div>

  <script>
    /***********************
     * 1) أدوات مساعدة عامة
     ***********************/
    function stringToUtf8Bytes(str) {
      return new TextEncoder().encode(str);
    }

    function utf8BytesToString(bytes) {
      return new TextDecoder().decode(bytes);
    }

    function xorBytes(dataBytes, keyBytes) {
      const out = new Uint8Array(dataBytes.length);
      for (let i = 0; i < dataBytes.length; i++) {
        out[i] = dataBytes[i] ^ keyBytes[i % keyBytes.length];
      }
      return out;
    }

    function bytesToBase64(bytes) {
      let binary = "";
      for (let i = 0; i < bytes.length; i++) {
        binary += String.fromCharCode(bytes[i]);
      }
      return btoa(binary);
    }

    function base64ToBytes(b64) {
      const binary = atob(b64);
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) {
        bytes[i] = binary.charCodeAt(i);
      }
      return bytes;
    }

    /************************************
     * 2) طبقة C: ترميز البلوكات إلى أرقام
     ************************************/

    // ملاحظة: هذا ترميز مبسط فقط كمثال
    // يمكنك استبداله بترميزك الحقيقي
    const ARABIC_CHARS = " اابتثجحخدذرزسشصضطظعغفقكلمنهويءآأؤإئىة";
    const CHAR_TO_CODE = {};
    const CODE_TO_CHAR = {};
    for (let i = 0; i < ARABIC_CHARS.length; i++) {
      CHAR_TO_CODE[ARABIC_CHARS[i]] = i;
      CODE_TO_CHAR[i] = ARABIC_CHARS[i];
    }
    const BASE = ARABIC_CHARS.length; // أساس النظام العددي

    // تقسيم كلمة إلى بلوكات (حتى 5 حروف)
    function splitWordToBlocks(word, blockSize = 5) {
      const blocks = [];
      for (let i = 0; i < word.length; i += blockSize) {
        blocks.push(word.slice(i, i + blockSize));
      }
      return blocks;
    }

    // تحويل بلوك (حتى 5 حروف) إلى رقم C
    function encodeBlockToC(block) {
      let value = 0;
      for (let i = 0; i < block.length; i++) {
        const ch = block[i];
        const code = CHAR_TO_CODE[ch] ?? 0;
        value = value * BASE + code;
      }
      return value;
    }

    // تحويل رقم C إلى بلوك (مع طول معروف)
    function decodeCToBlock(C, length) {
      let chars = [];
      let value = C;
      for (let i = 0; i < length; i++) {
        const code = value % BASE;
        value = Math.floor(value / BASE);
        chars.push(CODE_TO_CHAR[code] ?? " ");
      }
      chars.reverse();
      return chars.join("");
    }

    // تحويل نص كامل إلى قائمة من {len, C}
    function textToCList(text) {
      const words = text.split(/\s+/).filter(w => w.length > 0);
      const result = [];
      for (const word of words) {
        const blocks = splitWordToBlocks(word);
        for (const block of blocks) {
          const C = encodeBlockToC(block);
          result.push({ len: block.length, C });
        }
        // نضيف فاصل كلمة خاص (اختياري)
        result.push({ len: 0, C: -1 }); // -1 = فاصل كلمة
      }
      return result;
    }

    // تحويل قائمة {len, C} إلى نص
    function cListToText(cList) {
      let words = [];
      let currentWord = "";
      for (const item of cList) {
        if (item.C === -1 && item.len === 0) {
          if (currentWord.length > 0) {
            words.push(currentWord);
            currentWord = "";
          }
        } else {
          const block = decodeCToBlock(item.C, item.len);
          currentWord += block;
        }
      }
      if (currentWord.length > 0) {
        words.push(currentWord);
      }
      return words.join(" ");
    }

    /****************************************
     * 3) طبقة الثنائي: C → بتات والعكس
     ****************************************/

    // نحول كل C إلى 32 بت (كمثال ثابت)
    function cListToBinary(cList) {
      const bits = [];
      for (const item of cList) {
        // نخزن len في 3 بت (0..5 يكفي) + C في 29 بت (مثال)
        let len = item.len & 0b111; // 3 بت
        let C = item.C;
        if (C < 0) {
          // فاصل كلمة: نضع C = 0 ونستخدم len=0 كعلامة
          C = 0;
          len = 0;
        }
        // نخزن len في أول 3 بت، ثم C في 29 بت
        let value = (len << 29) | (C & 0x1FFFFFFF);
        for (let i = 31; i >= 0; i--) {
          bits.push((value >> i) & 1);
        }
      }
      return bits;
    }

    function binaryToCList(bits) {
      const cList = [];
      for (let i = 0; i < bits.length; i += 32) {
        if (i + 32 > bits.length) break;
        let value = 0;
        for (let j = 0; j < 32; j++) {
          value = (value << 1) | bits[i + j];
        }
        const len = (value >> 29) & 0b111;
        const C = value & 0x1FFFFFFF;
        if (len === 0) {
          cList.push({ len: 0, C: -1 }); // فاصل كلمة
        } else {
          cList.push({ len, C });
        }
      }
      return cList;
    }

    // تحويل مصفوفة بتات إلى بايتات
    function bitsToBytes(bits) {
      const byteLength = Math.ceil(bits.length / 8);
      const bytes = new Uint8Array(byteLength);
      for (let i = 0; i < bits.length; i++) {
        const byteIndex = Math.floor(i / 8);
        bytes[byteIndex] = (bytes[byteIndex] << 1) | bits[i];
      }
      // إكمال آخر بايت إن لم يكن مكتملًا
      const remaining = bits.length % 8;
      if (remaining !== 0) {
        bytes[byteLength - 1] <<= (8 - remaining);
      }
      return bytes;
    }

    // تحويل بايتات إلى بتات
    function bytesToBits(bytes) {
      const bits = [];
      for (let i = 0; i < bytes.length; i++) {
        let b = bytes[i];
        for (let j = 7; j >= 0; j--) {
          bits.push((b >> j) & 1);
        }
      }
      return bits;
    }

    /************************************
     * 4) التشفير البسيط بالمفتاح (XOR)
     ************************************/

    function encryptBytes(dataBytes, purchaseKey) {
      const keyBytes = stringToUtf8Bytes(purchaseKey);
      return xorBytes(dataBytes, keyBytes);
    }

    function decryptBytes(encBytes, purchaseKey) {
      const keyBytes = stringToUtf8Bytes(purchaseKey);
      return xorBytes(encBytes, keyBytes);
    }

    /************************************
     * 5) توليد ملف BRHM (JSON مبسط)
     ************************************/

    let lastBRHMObject = null;

    function encodeToBRHM() {
      const text = document.getElementById("inputText").value.trim();
      const key = document.getElementById("purchaseKey").value.trim();

      if (!text) {
        alert("الرجاء إدخال نص.");
        return;
      }
      if (!key) {
        alert("الرجاء إدخال مفتاح الشراء.");
        return;
      }

      // 1) نص → قائمة C
      const cList = textToCList(text);

      // 2) C → بتات
      const bits = cListToBinary(cList);

      // 3) بتات → بايتات
      const dataBytes = bitsToBytes(bits);

      // 4) تشفير بالـ XOR (مثال مبسط)
      const encBytes = encryptBytes(dataBytes, key);

      // 5) تحويل إلى Base64 للتخزين في JSON
      const encBase64 = bytesToBase64(encBytes);

      // 6) بناء كائن BRHM
      const brhm = {
        header: {
          version: 1,
          contentType: "text",
          language: "AR",
          encryption: "XOR-UTF8-KEY",
          compression: "NONE",
          bookId: "BOOK-001",
          userBinding: "PURCHASE-KEY",
          createdAt: new Date().toISOString()
        },
        body: {
          data: encBase64
        }
      };

      lastBRHMObject = brhm;
      document.getElementById("brhmOutput").textContent = JSON.stringify(brhm, null, 2);
      alert("تم توليد ملف BRHM (تجريبي). يمكنك تحميله الآن.");
    }

    function downloadBRHM() {
      if (!lastBRHMObject) {
        alert("لا يوجد ملف BRHM مولّد بعد.");
        return;
      }
      const blob = new Blob([JSON.stringify(lastBRHMObject)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "book.brhm.json";
      a.click();
      URL.revokeObjectURL(url);
    }

    /************************************
     * 6) فك ملف BRHM واسترجاع النص
     ************************************/

    function decodeBRHM() {
      const fileInput = document.getElementById("brhmFileInput");
      const key = document.getElementById("purchaseKeyDecode").value.trim();

      if (!fileInput.files || fileInput.files.length === 0) {
        alert("الرجاء اختيار ملف BRHM.");
        return;
      }
      if (!key) {
        alert("الرجاء إدخال مفتاح الشراء المستخدم في التشفير.");
        return;
      }

      const file = fileInput.files[0];
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const content = e.target.result;
          const brhm = JSON.parse(content);

          const encBase64 = brhm.body.data;
          const encBytes = base64ToBytes(encBase64);

          // فك التشفير
          const dataBytes = decryptBytes(encBytes, key);

          // بايتات → بتات
          const bits = bytesToBits(dataBytes);

          // بتات → قائمة C
          const cList = binaryToCList(bits);

          // قائمة C → نص
          const text = cListToText(cList);

          document.getElementById("decodedText").value = text;
        } catch (err) {
          console.error(err);
          alert("فشل فك الملف. ربما المفتاح غير صحيح أو الملف غير صالح.");
        }
      };
      reader.readAsText(file, "utf-8");
    }
  </script>
</body>
</html>
